{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  },
  "vueCompilerOptions": {
    "plugins": []
  },
  "include": [
    ".nuxt/nuxt.d.ts",
    ".nuxt/nuxt.node.d.ts",
    "app/**/*",
    "server/**/*",
    "shared/**/*",
    "tests/**/*",
    "*.ts",
    "*.mts"
  ]
}
