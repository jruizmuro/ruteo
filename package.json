{
  "name": "ruteo",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Planificador de rutas circulares para runners y ciclistas",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint . && nuxt typecheck",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/ui": "^4.0.0",
    "@nuxtjs/i18n": "^9.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/nuxt": "^14.3.0",
    "dayjs-nuxt": "^2.1.11",
    "nuxt": "^4.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^3.23.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^16.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "msw": "^2.7.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.2.0"
  },
  "lint-staged": {
    "*.{js,ts,vue,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "msw",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
